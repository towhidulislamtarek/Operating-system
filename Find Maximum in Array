#include <stdio.h>

int main() {
    int n, i, max;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr[n];

    printf("Enter %d elements: ", n);
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    max = arr[0]; // প্রথম element ধরে নেওয়া হচ্ছে maximum

    for(i = 1; i < n; i++) {
        if(arr[i] > max) {
            max = arr[i];
        }
    }

    printf("Maximum element: %d", max);

    return 0;
}
