#include <stdio.h>
#include <string.h>

int main() {
    FILE *file;
    char filename[100], word[50], temp[100];
    int count = 0;

    printf("Enter filename: ");
    scanf("%s", filename);

    printf("Enter word to count: ");
    scanf("%s", word);

    file = fopen(filename, "r");
    if(file == NULL) {
        printf("Could not open file %s\n", filename);
        return 1;
    }

    // read file word by word
    while(fscanf(file, "%s", temp) != EOF) {
        if(strcmp(temp, word) == 0) {
            count++;
        }
    }

    fclose(file);

    printf("%s occurs %d times\n", word, count);

    return 0;
}
