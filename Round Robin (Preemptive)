#include <stdio.h>
#define MAX 100

int main() {
    int n, tq;
    printf("Enter number of processes: ");
    scanf("%d", &n);

    int at[MAX], bt[MAX], rem_bt[MAX];
    int ct[MAX], tat[MAX], wt[MAX], rt[MAX];
    int inQueue[MAX];

    for (int i = 0; i < n; i++) {
        printf("Enter AT and BT for P%d: ", i + 1);
        scanf("%d %d", &at[i], &bt[i]);
        rem_bt[i] = bt[i];
        rt[i] = -1;
        inQueue[i] = 0;
    }

    printf("Enter Time Quantum: ");
    scanf("%d", &tq);

    int q[10000], front = 0, rear = 0;
    int time = 0, completed = 0;

    // Gantt chart: -1 means IDLE
    int gantt_p[10000], gantt_time[10001];
    int g = 0;

    // Find process with earliest arrival to start
    int min_at = at[0], start_idx = 0;
    for (int i = 1; i < n; i++) {
        if (at[i] < min_at) {
            min_at = at[i];
            start_idx = i;
        }
    }

    time = min_at;
    q[rear++] = start_idx;
    inQueue[start_idx] = 1;

    while (completed < n) {

        if (front == rear) {
            // Queue empty — CPU is IDLE
            if (g == 0 || gantt_p[g - 1] != -1) {
                gantt_p[g] = -1;
                gantt_time[g] = time;
                g++;
            }
            // Jump to next arriving process
            int min_arr = 100000, idx = -1;
            for (int i = 0; i < n; i++) {
                if (rem_bt[i] > 0 && at[i] < min_arr) {
                    min_arr = at[i];
                    idx = i;
                }
            }
            time = min_arr;
            q[rear++] = idx;
            inQueue[idx] = 1;
            continue;
        }

        int i = q[front++];

        // Response time
        if (rt[i] == -1) {
            rt[i] = time - at[i];
        }

        // Gantt entry
        gantt_p[g] = i;
        gantt_time[g++] = time;

        if (rem_bt[i] > tq) {
            time += tq;
            rem_bt[i] -= tq;
        } else {
            time += rem_bt[i];
            rem_bt[i] = 0;
            ct[i] = time;
            completed++;
        }

        // Add newly arrived processes to queue
        for (int j = 0; j < n; j++) {
            if (at[j] <= time && rem_bt[j] > 0 && !inQueue[j]) {
                q[rear++] = j;
                inQueue[j] = 1;
            }
        }

        // Reinsert current process if not finished
        if (rem_bt[i] > 0) {
            q[rear++] = i;
        }
    }

    // Store final time
    gantt_time[g] = time;

    // Calculate TAT & WT
    for (int i = 0; i < n; i++) {
        tat[i] = ct[i] - at[i];
        wt[i] = tat[i] - bt[i];
    }

    // Print Table
    printf("\nProcess\tAT\tBT\tCT\tTAT\tWT\tRT\n");
    for (int i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
               i + 1, at[i], bt[i], ct[i], tat[i], wt[i], rt[i]);
    }

    // Gantt Chart
    printf("\nGantt Chart:\n");
    for (int i = 0; i < g; i++) {
        if (gantt_p[i] == -1)
            printf("| IDLE ");
        else
            printf("| P%d  ", gantt_p[i] + 1);
    }
    printf("|\n");
    printf("%d", gantt_time[0]);
    for (int i = 1; i <= g; i++) {
        printf("     %d", gantt_time[i]);
    }
    printf("\n");

    return 0;
}
