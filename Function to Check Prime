#include <stdio.h>

// Function declaration
int isPrime(int num);

int main() {
    int n;

    printf("Enter a number: ");
    scanf("%d", &n);

    if(isPrime(n))
        printf("%d is prime", n);
    else
        printf("%d is not prime", n);

    return 0;
}

// Function definition
int isPrime(int num) {
    int i;

    if(num <= 1)
        return 0; // not prime

    for(i = 2; i <= num/2; i++) {
        if(num % i == 0)
            return 0; // not prime
    }

    return 1; // prime
}
